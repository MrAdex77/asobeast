generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Store {
  GOOGLE_PLAY
  APP_STORE
}

enum KeywordSource {
  TITLE
  SUBTITLE
  DESCRIPTION
  KEYWORD_FIELD
  SUGGESTED
  MANUAL
  COMPETITOR
}

model Workspace {
  id          String       @id @default(cuid())
  name        String       @default("Default")
  apps        App[]
  appGroups   AppGroup[]
  webhooks    Webhook[]
  emailAlerts EmailAlert[]
  alertEvents AlertEvent[]
  createdAt   DateTime     @default(now())
}

model AppGroup {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  apps        App[]
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

model App {
  id           String           @id @default(cuid())
  workspaceId  String
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  store        Store
  storeAppId   String
  country      String           @default("us")
  name         String?
  iconUrl      String?
  isCompetitor Boolean          @default(false)
  primaryAppId String?
  primaryApp   App?             @relation("AppCompetitors", fields: [primaryAppId], references: [id], onDelete: Cascade)
  competitors  App[]            @relation("AppCompetitors")
  groupId      String?
  group        AppGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  snapshots    AppSnapshot[]
  tracked      TrackedKeyword[]
  rankings     KeywordRanking[]
  categoryRanks CategoryRank[]
  changeEvents ChangeEvent[]
  reviews      Review[]
  suggestProbes SuggestProbe[]
  auditInput   AuditInput?
  auditScores  AuditScore[]
  createdAt    DateTime         @default(now())

  @@unique([workspaceId, store, storeAppId, country])
  @@unique([groupId, store])
  @@index([workspaceId])
  @@index([primaryAppId])
  @@index([groupId])
}

model AppSnapshot {
  id             String    @id @default(cuid())
  appId          String
  app            App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  title          String
  subtitle       String?
  summary        String?
  description    String
  ratingAvg      Float?
  ratingCount    Int?
  installs       BigInt?
  price          Float?
  version        String?
  releasedAt     DateTime?
  storeUpdatedAt DateTime?
  raw            Json
  capturedAt     DateTime  @default(now())

  @@index([appId, capturedAt])
}

model Keyword {
  id          String           @id @default(cuid())
  text        String
  store       Store
  country     String           @default("us")
  metrics     KeywordMetric[]
  tracked     TrackedKeyword[]
  rankings    KeywordRanking[]
  serpEntries SerpEntry[]
  createdAt   DateTime         @default(now())

  @@unique([text, store, country])
}

model TrackedKeyword {
  appId     String
  app       App           @relation(fields: [appId], references: [id], onDelete: Cascade)
  keywordId String
  keyword   Keyword       @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  source    KeywordSource
  active    Boolean       @default(true)
  relevance Int?
  createdAt DateTime      @default(now())

  @@id([appId, keywordId])
  @@index([keywordId])
}

model AuditInput {
  appId     String   @id
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  answers   Json
  updatedAt DateTime @updatedAt
}

model KeywordMetric {
  keywordId  String
  keyword    Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  traffic    Float?
  difficulty Float?
  stats      Json?
  createdAt  DateTime @default(now())

  @@id([keywordId, date])
}

model KeywordRanking {
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  keywordId String
  keyword   Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  position  Int?
  depth     Int      @default(100)
  createdAt DateTime @default(now())

  @@id([appId, keywordId, date])
  @@index([keywordId, date])
  @@index([appId, date])
}

model CategoryRank {
  appId      String
  app        App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  collection String
  genre      String
  position   Int?
  depth      Int      @default(200)
  createdAt  DateTime @default(now())

  @@id([appId, date, collection, genre])
  @@index([appId, date])
}

model SerpEntry {
  keywordId   String
  keyword     Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  position    Int
  storeAppId  String
  title       String
  developer   String?
  ratingAvg   Float?
  ratingCount Int?
  createdAt   DateTime @default(now())

  @@id([keywordId, date, position])
  @@index([storeAppId, date])
  @@index([keywordId, date])
}

model ChangeEvent {
  id         String   @id @default(cuid())
  appId      String
  app        App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  field      String
  before     String?
  after      String?
  capturedAt DateTime @default(now())

  @@index([appId, capturedAt])
}

model Review {
  id         String    @id @default(cuid())
  appId      String
  app        App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  reviewId   String
  userName   String?
  score      Int
  title      String?
  text       String
  version    String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([appId, reviewId])
  @@index([appId, reviewedAt])
  @@index([appId, score])
}

model Webhook {
  id          String          @id @default(cuid())
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  url         String
  events      String[]
  secret      String?
  active      Boolean         @default(true)
  deliveries  AlertDelivery[]
  createdAt   DateTime        @default(now())

  @@index([workspaceId])
}

model EmailAlert {
  id          String          @id @default(cuid())
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  events      String[]
  active      Boolean         @default(true)
  deliveries  AlertDelivery[]
  createdAt   DateTime        @default(now())

  @@index([workspaceId])
}

model AlertDelivery {
  id           String      @id @default(cuid())
  channel      String
  webhookId    String?
  webhook      Webhook?    @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  emailAlertId String?
  emailAlert   EmailAlert? @relation(fields: [emailAlertId], references: [id], onDelete: Cascade)
  event        String
  status       String
  detail       String?
  attempt      Int
  createdAt    DateTime    @default(now())

  @@index([webhookId, createdAt])
  @@index([emailAlertId, createdAt])
  @@index([createdAt])
}

model AlertEvent {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  event       String
  appId       String?
  dedupeKey   String?   @unique
  payload     Json
  createdAt   DateTime  @default(now())
  flushedAt   DateTime?

  @@index([workspaceId, flushedAt])
  @@index([createdAt])
}

model SuggestProbe {
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  term      String
  day       DateTime @db.Date
  probe     String
  results   Json
  createdAt DateTime @default(now())

  @@id([appId, term, day, probe])
}

model AuditScore {
  appId         String
  app           App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  overall       Float?
  coveredWeight Int
  totalWeight   Int
  factors       Json
  createdAt     DateTime @default(now())

  @@id([appId, date])
  @@index([appId, date])
}
