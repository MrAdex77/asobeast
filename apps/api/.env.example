DATABASE_URL=postgresql://asobeast:asobeast@localhost:5432/asobeast
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
PORT=4000
DEFAULT_COUNTRY=us
CRON_DAILY=0 3 * * *        # daily pipeline, UTC
CRON_SCORING=0 4 * * 0      # weekly scoring, UTC (Sunday)
SCRAPE_ITUNES_RPM=15
SCRAPE_GPLAY_RPM=10           # google play job-starts/minute; halve if BlockedError appears in the delivery log
ALERT_RANK_DROP_THRESHOLD=5   # positions a primary app must fall/rise to alert
ALERT_REVIEW_SCORE_MAX=2      # reviews at or below this star rating fire review.negative (1-4)
RETENTION_RANKINGS_DAYS=365       # prune keyword rankings older than N days; 0 keeps forever
RETENTION_SERP_DAYS=90            # prune serp entries older than N days; 0 keeps forever
RETENTION_SNAPSHOTS_DAYS=180      # prune app snapshots older than N days; newest per app always kept; 0 keeps forever
RETENTION_CATEGORY_RANKS_DAYS=365 # prune category ranks older than N days; 0 keeps forever
RETENTION_CHANGE_EVENTS_DAYS=0    # prune change events older than N days; 0 keeps forever
RETENTION_DELIVERIES_DAYS=30      # prune alert delivery log rows older than N days; 0 keeps forever
CRON_RETENTION=0 5 * * *          # data retention pruning, UTC
CRON_DIGEST=0 8 * * 1             # weekly digest webhook, UTC (Monday 08:00)
# SMTP for email alerts — leave SMTP_HOST/SMTP_FROM empty to disable email alerts
SMTP_HOST=                        # e.g. smtp.example.com or localhost for a relay
SMTP_PORT=587                     # 465 with SMTP_SECURE=true, otherwise 587/25
SMTP_SECURE=false                 # true wraps the connection in TLS (port 465)
SMTP_USER=                        # optional; leave empty for unauthenticated relays
SMTP_PASSWORD=                    # optional
SMTP_FROM=                        # e.g. asobeast <alerts@example.com>
BULL_BOARD_ENABLED=true
BULL_BOARD_USER=                  # set both to protect /admin/queues with basic auth
BULL_BOARD_PASSWORD=
LOG_LEVEL=debug
